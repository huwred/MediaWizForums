@using Umbraco.Extensions
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage

@{
    Layout = "ForumMaster.cshtml";
    string userqry = "";
    if (Context.Request.Query.ContainsKey("user"))
    {
        userqry = Context.Request.Query["user"].ToString();
    }
}
@section ForumHeader{
    <meta name="robots" content="noindex,nofollow" />
}

<div class="wiz-forum-info">
    <div class="page-header">
        <h3>@Model.Value("title")</h3>
    </div>
    <div class="forum-intro">
        @Html.Raw(Model.Value("message"))
    </div>
</div>
@if (Context.Request.Query.ContainsKey("user"))
{
    @await Component.InvokeAsync("ForumMembership",new {Template = "EditProfile",qryUser = userqry})
}
