<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
      <AssemblyVersion>10.2.3</AssemblyVersion>
      <Version>10.2.3</Version>
      <InformationalVersion>10.2.3</InformationalVersion>
      <TargetFramework>net6.0</TargetFramework>
        <ContentTargetFolders>.</ContentTargetFolders>
        <Product>MediaWizard Forums</Product>
        <PackageId>MediaWiz.Forums</PackageId>
        <Title>MediaWizard Forums</Title>
        <Description>MediaWiz Forums for Umbraco CMS. Built for Umbraco 10</Description>
        <Authors>Huw Reddick</Authors>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageProjectUrl>https://umbraco.themediawizards.co.uk</PackageProjectUrl>
    </PropertyGroup>

  <PropertyGroup>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);CopyProjectReferencesToPackage</TargetsForTfmSpecificBuildOutput>
    <Copyright>Huw Reddick</Copyright>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
  </PropertyGroup>
  <Target Name="CopyProjectReferencesToPackage" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths-&gt;WithMetadataValue('ReferenceSourceTarget', 'ProjectReference'))" />
    </ItemGroup>
  </Target>

    <ItemGroup>
        <PackageReference Include="Umbraco.Cms.Web.Website" Version="10.2.0" />
        <PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="10.2.0" />
    </ItemGroup>

    <ItemGroup>
        <None Include="build\**\*.*">
            <Pack>true</Pack>
            <PackagePath>buildTransitive</PackagePath>
        </None>
      <Content Include="wwwroot\**\*.*">
        <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
        <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      </Content>

      <None Remove="Migrations\package.zip" />
      <EmbeddedResource Include="Migrations\package.zip" />

    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\MediaWiz.Core\MediaWiz.Core.csproj" PrivateAssets="All" />
    </ItemGroup>

</Project>
